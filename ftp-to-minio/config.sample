# Copy to config.env on the MinIO host, fill in, then:
#   set -a; source ./config.env; set +a
#   ./sync.sh --dry-run     # preview
#   ./sync.sh               # run
# Do NOT commit config.env.

# --- FTP source ---
FTP_HOST=ftp.example.com
FTP_PORT=21
FTP_USER=ftpuser
FTP_PASS=REPLACE_ME
FTP_TLS=false            # true = explicit FTPS (recommended if supported)
FTP_PATH=/              # path on FTP to migrate

# --- local folder destination (only for ftp-to-folder.sh) ---
DEST_DIR=/data/ftp-mirror

# --- MinIO destination (rclone runs ON this host -> localhost) ---
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME
MINIO_REGION=us-east-1
BUCKET=migrated
PREFIX=                  # optional sub-path inside bucket, e.g. ftp/

# --- Tuning (defaults sane for >500GB / millions of files) ---
TRANSFERS=8
CHECKERS=8
# FTP connection cap. 0 = unlimited. If non-zero it MUST exceed
# TRANSFERS+CHECKERS or rclone's FTP backend DEADLOCKS (0 B/s, stuck).
# Script auto-raises a too-low value. Many FTP servers cap per-IP, so if you
# get "too many connections", set a number like 24 instead of 0.
FTP_CONCURRENCY=0
S3_CHUNK_SIZE=64M        # RAM budget ~= CHUNK * S3_CONCURRENCY * TRANSFERS
S3_CONCURRENCY=4
LOG_DIR=./logs
